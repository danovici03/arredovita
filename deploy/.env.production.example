# Copy to .env on the VPS (next to docker-compose.yml). Do NOT commit the real file.
# Generate strong secrets:  openssl rand -hex 32

# --- Postgres ---
POSTGRES_USER=medusa
POSTGRES_PASSWORD=REPLACE_ME_strong_password
POSTGRES_DB=medusa

# --- Medusa secrets (64 hex chars each) ---
JWT_SECRET=REPLACE_ME_openssl_rand_hex_32
COOKIE_SECRET=REPLACE_ME_openssl_rand_hex_32

# --- CORS (must match the domains Caddy serves) ---
STORE_CORS=https://arredovita.it,https://www.arredovita.it
ADMIN_CORS=https://api.arredovita.it
AUTH_CORS=https://arredovita.it,https://www.arredovita.it,https://api.arredovita.it

# --- First-boot admin user (delete after first successful login) ---
ADMIN_EMAIL=office@danovicidesign.com
ADMIN_PASSWORD=REPLACE_ME_initial_admin_password

# --- Storefront ---
# After first deploy:
#   1. Log into https://api.arredovita.it/app
#   2. Settings -> Publishable API Keys -> create/copy one bound to the default sales channel
#   3. Paste it here and run: docker compose up -d --build storefront
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_ME
NEXT_PUBLIC_STRIPE_KEY=

# --- Storefront on-demand revalidation ---
# Set the same REVALIDATE_SECRET on both backend and storefront. The backend
# subscriber POSTs to STOREFRONT_REVALIDATE_URL whenever a category, product or
# collection changes, so the Next.js cache invalidates without a redeploy.
STOREFRONT_REVALIDATE_URL=https://arredovita.it/api/revalidate
REVALIDATE_SECRET=REPLACE_ME_openssl_rand_hex_16
