# Staging / test environment for Dokploy
# Backend Medusa on:  https://api.arredo.danovicidesign.com
# Storefront on Vercel:  https://arredo.danovicidesign.com
#
# Generate strong secrets with:  openssl rand -hex 32
# Paste each variable into Dokploy -> Application -> Environment Variables.

# --- Database connections (use the INTERNAL hostnames Dokploy gives you) ---
# Format from Dokploy when you create a Postgres service:
#   postgres://<user>:<password>@<service-name>:5432/<db>
DATABASE_URL=postgres://medusa:REPLACE_ME_pg_password@arredo-staging-postgres:5432/medusa

# Format from Dokploy when you create a Redis service:
#   redis://<service-name>:6379
REDIS_URL=redis://arredo-staging-redis:6379

# --- Runtime ---
NODE_ENV=production

# --- Medusa secrets (64 hex chars each, unique per environment) ---
JWT_SECRET=REPLACE_ME_openssl_rand_hex_32
COOKIE_SECRET=REPLACE_ME_openssl_rand_hex_32

# --- CORS ---
# STORE_CORS = origins from which the storefront calls /store/*
# ADMIN_CORS = origin where the Medusa admin UI is served (same as backend domain)
# AUTH_CORS  = every origin that needs to hit /auth/* (storefront + admin)
#
# IMPORTANT: include https://*.vercel.app preview URLs only if you actively
# test from preview deployments. Otherwise keep it tight.
STORE_CORS=https://arredo.danovicidesign.com
ADMIN_CORS=https://api.arredo.danovicidesign.com
AUTH_CORS=https://arredo.danovicidesign.com,https://api.arredo.danovicidesign.com

# --- Backend public URL (used by the embedded admin UI) ---
MEDUSA_BACKEND_URL=https://api.arredo.danovicidesign.com
MEDUSA_ADMIN_BACKEND_URL=https://api.arredo.danovicidesign.com
DISABLE_MEDUSA_ADMIN=false

# --- First-boot bootstrap (docker-entrypoint.sh handles these) ---
# Migrations are idempotent; leave RUN_MIGRATIONS=true so each deploy re-syncs schema.
RUN_MIGRATIONS=true
# Admin user is created on first boot, then "user already exists" on subsequent ones.
# Safe to leave set, but rotate the password after first login.
CREATE_ADMIN_EMAIL=office@danovicidesign.com
CREATE_ADMIN_PASSWORD=REPLACE_ME_initial_admin_password

# --- Storefront on-demand revalidation ---
# The backend subscriber POSTs here on product/category/collection events so the
# Next.js cache invalidates without a redeploy. REVALIDATE_SECRET must equal the
# storefront's REVALIDATE_SECRET (see .env.staging.vercel.example).
STOREFRONT_REVALIDATE_URL=https://arredo.danovicidesign.com/api/revalidate
REVALIDATE_SECRET=REPLACE_ME_openssl_rand_hex_16
