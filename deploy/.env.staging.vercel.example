# Staging / test environment for Vercel (storefront)
# Storefront:  https://arredo.danovicidesign.com
# Backend:     https://api.arredo.danovicidesign.com
#
# Add these in Vercel -> Project -> Settings -> Environment Variables.
# Scope them to a dedicated "Preview" branch (e.g. `staging`) or to "Production"
# of a separate Vercel project, whichever you prefer for test.
#
# REMINDER: every NEXT_PUBLIC_* variable is baked into the build.
# After changing any of them you MUST trigger a redeploy, not just a restart.

# --- Backend wiring ---
MEDUSA_BACKEND_URL=https://api.arredo.danovicidesign.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.arredo.danovicidesign.com

# --- Storefront identity ---
NEXT_PUBLIC_BASE_URL=https://arredo.danovicidesign.com
NEXT_PUBLIC_DEFAULT_REGION=it

# --- Publishable key ---
# Create AFTER the backend is up:
#   1. Log into https://api.arredo.danovicidesign.com/app
#   2. Settings -> Publishable API Keys -> "Add publishable API key"
#   3. Bind it to the default Sales Channel
#   4. Paste the pk_... value below and redeploy the storefront
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_ME

# --- Optional: Stripe (use TEST keys on staging) ---
NEXT_PUBLIC_STRIPE_KEY=

# --- ISR / on-demand revalidation ---
# Same value must be set on the backend if you wire a webhook back to the storefront.
REVALIDATE_SECRET=REPLACE_ME_openssl_rand_hex_16
